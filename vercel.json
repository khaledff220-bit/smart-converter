{
  "version": 2,
  "name": "smart-converter-pwa",
  
  "regions": ["all"],
  
  "cleanUrls": true,
  
  "trailingSlash": false,
  
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "images/*.*",
      "use": "@vercel/static"
    }
  ],
  
  "routes": [
    {
      "src": "^/robots\\.txt$",
      "dest": "/robots.txt"
    },
    {
      "src": "^/sitemap\\.xml$",
      "dest": "/sitemap.xml"
    },
    {
      "src": "^/manifest\\.json$",
      "dest": "/manifest.json"
    },
    {
      "src": "^/service-worker\\.js$",
      "dest": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "^/BingSiteAuth\\.xml$",
      "dest": "/BingSiteAuth.xml"
    },
    {
      "src": "^/about/?$",
      "dest": "/about.html"
    },
    {
      "src": "^/privacy/?$",
      "dest": "/privacy.html"
    },
    {
      "src": "^/about\\.html$",
      "dest": "/about.html"
    },
    {
      "src": "^/privacy\\.html$",
      "dest": "/privacy.html"
    },
    {
      "src": "^/(.*)\\.(js|css|ico|jpg|jpeg|png|webp|svg|woff|woff2|eot|ttf|otf)$",
      "dest": "/$1.$2",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/(.*)\\.(html|xml|json)$",
      "dest": "/$1.$2",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "^/images/(.*)$",
      "dest": "/images/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)/?$",
      "dest": "/index.html",
      "status": 200
    }
  ],
  
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "^/service-worker\\.js$",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "^/manifest\\.json$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ],
  
  "rewrites": [
    {
      "source": "/currency",
      "destination": "/index.html#currency"
    },
    {
      "source": "/length",
      "destination": "/index.html#length"
    },
    {
      "source": "/weight",
      "destination": "/index.html#weight"
    },
    {
      "source": "/temperature",
      "destination": "/index.html#temperature"
    },
    {
      "source": "/date",
      "destination": "/index.html#date"
    }
  ],
  
  "redirects": [
    {
      "source": "/old-home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/about-us",
      "destination": "/about",
      "permanent": true
    }
  ],
  
  "overrides": [
    {
      "path": "*.html",
      "contentType": "text/html; charset=utf-8"
    },
    {
      "path": "*.js",
      "contentType": "application/javascript; charset=utf-8"
    },
    {
      "path": "*.css",
      "contentType": "text/css; charset=utf-8"
    },
    {
      "path": "*.json",
      "contentType": "application/json; charset=utf-8"
    },
    {
      "path": "*.xml",
      "contentType": "application/xml; charset=utf-8"
    },
    {
      "path": "*.txt",
      "contentType": "text/plain; charset=utf-8"
    }
  ]
}
